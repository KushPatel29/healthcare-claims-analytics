{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.0.0/schema.json",
  "name": "visual030",
  "position": {
    "x": 20,
    "y": 150,
    "z": 30000,
    "height": 280,
    "width": 620,
    "tabOrder": 30000
  },
  "visual": {
    "visualType": "clusteredColumnChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "ar_yield_predictions"
                    }
                  },
                  "Property": "payer_type"
                }
              },
              "queryRef": "ar_yield_predictions.payer_type",
              "nativeQueryRef": "payer_type"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Gross AR (Worklist) $"
                }
              },
              "queryRef": "_Measures.Gross AR (Worklist) $",
              "nativeQueryRef": "Gross AR (Worklist) $"
            },
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Expected NRV $"
                }
              },
              "queryRef": "_Measures.Expected NRV $",
              "nativeQueryRef": "Expected NRV $"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true,
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Gross AR vs Net Realizable Value by Payer Type'"
                }
              }
            },
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
          }
        }
      ]
    }
  }
}
