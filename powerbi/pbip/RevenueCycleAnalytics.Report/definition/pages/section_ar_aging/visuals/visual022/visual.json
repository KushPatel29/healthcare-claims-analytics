{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.0.0/schema.json",
  "name": "visual022",
  "position": {
    "x": 20,
    "y": 150,
    "z": 22000,
    "height": 280,
    "width": 620,
    "tabOrder": 22000
  },
  "visual": {
    "visualType": "columnChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "fact_claims"
                    }
                  },
                  "Property": "ar_bucket"
                }
              },
              "queryRef": "fact_claims.ar_bucket",
              "nativeQueryRef": "ar_bucket"
            }
          ]
        },
        "Series": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "dim_payer"
                    }
                  },
                  "Property": "payer_type"
                }
              },
              "queryRef": "dim_payer.payer_type",
              "nativeQueryRef": "payer_type"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Open AR $"
                }
              },
              "queryRef": "_Measures.Open AR $",
              "nativeQueryRef": "Open AR $"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true,
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Open AR by Aging Bucket and Payer Type'"
                }
              }
            },
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
          }
        }
      ]
    }
  }
}
